# EditorConfig helps maintain consistent coding styles across editors and IDEs
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.gradle]
indent_style = space
indent_size = 4

[*.java]
indent_style = space
indent_size = 4
continuation_indent_size = 8
max_line_length = 120
insert_final_newline = true
